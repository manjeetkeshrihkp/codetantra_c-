#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    if (n > 100) {
        cout << "Invalid";
        return 0;
    }

    bool found = false;

    for (int i = 2; i <= n; i++) {
        bool prime = true;

        for (int j = 2; j < i; j++) {
            if (i % j == 0) {
                prime = false;
                break;
            }
        }

        if (prime) {
            cout << i << " ";
            found = true;
        }
    }

    if (!found) {
        cout << "No primes";
    }

    return 0;
}
