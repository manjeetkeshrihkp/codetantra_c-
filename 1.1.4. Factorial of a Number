#include <iostream>
using namespace std;

// Function to calculate factorial using recursion
int factorial(int n) {
   if(n == 0 || n == 1){
	   return 1;
   }else 
	return n*factorial(n - 1);// Recursive case
   
}
int main() {
    int num;
    
    // Input the number
    cin >> num;
    
    // Call the factorial function and display the result
    cout << factorial(num) << endl;
    
    return 0;
}
